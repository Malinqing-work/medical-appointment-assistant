<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hospital.app.mapper.SchedulesMapper">
    <select id="list" resultType="com.hospital.app.domain.dto.ScheduleDTO">
        select * from
        schedule_dto_view
        where deleted = 0
        <if test="doctorName != null">
            and doctor_name like concat('%',#{doctorName},'%')
        </if>
    </select>
    <select id="listByDoctor" resultType="com.hospital.app.domain.dto.ScheduleDTO">
        select * from
        schedule_dto_view
        where deleted = 0
        and doctor_name = #{doctorName}
    </select>
</mapper>