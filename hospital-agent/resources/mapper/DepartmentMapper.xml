<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hospital.app.mapper.DepartmentsMapper">
    <select id="list" resultType="com.hospital.app.domain.Departments">
        select
            department_name
            from departments
        where deleted = 0
    </select>
</mapper>